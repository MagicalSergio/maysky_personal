---
import "../styles/reset.css";
import "../styles/fonts.css";
import "../styles/base.scss";
import FooterComponent from "./FooterComponent.vue";

const { title = "maysky", description = "Personal website" } = Astro.props;
---

<script>
  import { getScroll } from "../scripts/scroll";
  getScroll();
</script>

<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="maysky" />
    <title>{title}</title>
    <style is:inline>
      html {
        overflow-y: scroll;
      }

      html.app-loading body {
        overflow: hidden;
        height: 100vh;
      }

      #app-loader {
        position: fixed;
        inset: 0;
        top: 0;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 9999;
        background: black;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
        transition: transform 1.5s ease;
        pointer-events: none;
        user-select: none;
      }

      #app-loader.app-loader--hidden {
        transform: translateY(-100%);
      }

      #app-loader.app-loader--hidden .app-loader__progress-wrap {
        display: none;
      }

      .app-loader__svg {
        width: 140px;
        height: 140px;
        overflow: visible;
      }

      .app-loader__arc-outer {
        transform-box: fill-box;
        transform-origin: center;
        animation: arc-cw 3.5s linear infinite;
      }

      .app-loader__arc-inner {
        transform-box: fill-box;
        transform-origin: center;
        animation: arc-ccw 2s linear infinite;
      }

      @keyframes arc-cw {
        to {
          transform: rotate(360deg);
        }
      }

      @keyframes arc-ccw {
        to {
          transform: rotate(-360deg);
        }
      }

      .app-loader__label {
        font-family: "JetBrains Mono", "Courier New", monospace;
        font-size: 20px;
        letter-spacing: -0.02em;
        text-transform: uppercase;
        color: #333333;
      }

      .app-loader__spinner {
        display: inline-block;
        width: 1ch;
      }

      .app-loader__progress-wrap {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1rem;
        background: #1a1a1a;
      }

      .app-loader__progress-bar {
        height: 100%;
        background: #555555;
        width: 0;
        animation: progress-fill 5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        transition: width 0.25s ease;
      }

      @keyframes progress-fill {
        0% {
          width: 0%;
        }
        20% {
          width: 28%;
        }
        50% {
          width: 58%;
        }
        80% {
          width: 80%;
        }
        100% {
          width: 90%;
        }
      }
    </style>
  </head>
  <body>
    <div id="app-loader">
      <svg class="app-loader__svg" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Outer track -->
        <circle cx="60" cy="60" r="48" stroke="#1c1c1c" stroke-width="1"></circle>
        <!-- Outer arc: circ≈301, 3/4 arc -->
        <circle
          class="app-loader__arc-outer"
          cx="60"
          cy="60"
          r="48"
          stroke="#484848"
          stroke-width="1"
          stroke-linecap="round"
          stroke-dasharray="226 76"></circle>

        <!-- Inner track -->
        <circle cx="60" cy="60" r="32" stroke="#1c1c1c" stroke-width="1"></circle>
        <!-- Inner arc: circ≈201, ~1/3 arc -->
        <circle
          class="app-loader__arc-inner"
          cx="60"
          cy="60"
          r="32"
          stroke="#d0d0d0"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="70 131"></circle>

        <!-- Center fill -->
        <circle cx="60" cy="60" r="19" fill="#101010"></circle>
      </svg>

      <p class="app-loader__label">
        <span class="app-loader__label-text">loading</span>
        <span class="app-loader__spinner"></span>
      </p>

      <div class="app-loader__progress-wrap">
        <div class="app-loader__progress-bar"></div>
      </div>
    </div>

    <script is:inline>
      (async function () {
        document.documentElement.classList.add("app-loading");

        const spinnerEl = document.querySelector(".app-loader__spinner");
        const spinnerFrames = ["/", "|", "\\", "-"];
        let spinnerIdx = 0;
        const spinnerInterval = setInterval(() => {
          spinnerEl.textContent = spinnerFrames[spinnerIdx++ % 4];
        }, 120);

        await Promise.all([
          document.fonts.ready,
          new Promise((r) => {
            window.addEventListener("load", r, { once: true });
          }),
          new Promise((r) => {
            window.addEventListener("app:scene-ready", r, { once: true });
            setTimeout(r, 10000);
          }),
        ]);

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const loader = document.getElementById("app-loader");
            if (!loader) return;
            clearInterval(spinnerInterval);

            setTimeout(() => {
              document.documentElement.classList.remove("app-loading");
              loader.classList.add("app-loader--hidden");
              loader.addEventListener("transitionend", loader.remove, { once: true });
            }, 280);
          });
        });
      })();
    </script>

    <slot />
    <FooterComponent client:load />
  </body>
</html>
